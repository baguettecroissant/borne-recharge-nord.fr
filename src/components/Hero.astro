---
import config from '../data/config.json';
import StepsForm from './StepsForm.astro';

interface Props {
  communeName?: string;
  categoryName?: string;
}

const { communeName = config.mainCity, categoryName = "" } = Astro.props;

let titlePrefix = "Installation Borne de Recharge";
if (categoryName === "Copropriété") {
  titlePrefix = "Borne de Recharge en Copropriété";
} else if (categoryName === "Wallbox") {
  titlePrefix = "Installation de Wallbox Rapide";
} else if (categoryName === "Prise") {
  titlePrefix = "Installation de Prise Green'Up";
}
---

<style>
  .hero-with-bg {
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.98) 0%, rgba(30, 58, 95, 0.94) 100%), url('/images/hero-borne-recharge-nord.png') no-repeat center center;
    background-size: cover;
  }
  @media (min-width: 993px) {
    .hero-with-bg {
      background: linear-gradient(90deg, rgba(15, 23, 42, 0.98) 0%, rgba(30, 58, 95, 0.92) 50%, rgba(30, 58, 95, 0.4) 100%), url('/images/hero-borne-recharge-nord.png') no-repeat center center;
      background-size: cover;
    }
  }
  .aides-badge-pill {
    display: inline-block;
    background: var(--accent);
    color: white;
    font-weight: 800;
    font-size: 12px;
    padding: 6px 14px;
    border-radius: 50px;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 10px rgba(16, 185, 129, 0.3);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 50px;
    align-items: center;
  }
  .trust-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-top: 30px;
  }
  .trust-badges .badge {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.08);
    padding: 8px 16px;
    border-radius: 50px;
    font-size: 13.5px;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }
  .trust-badges .badge svg {
    width: 18px;
    height: 18px;
    color: var(--accent);
  }
  @media (max-width: 992px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 35px;
    }
    .trust-badges {
      justify-content: center;
    }
  }
</style>

<section class="hero hero-with-bg">
  <div class="container hero-grid">
    <!-- Left Column -->
    <div class="hero-content">
      <div class="aides-badge-pill">Prime ADVENIR 2026 jusqu'à 960€</div>
      <h1 style="color: white; font-size: 40px; font-family: var(--font-heading); line-height: 1.2; margin-bottom: 20px;">
        {titlePrefix} à <span style="color: var(--accent);">{communeName}</span> et dans le <span style="color: var(--accent);">{config.department}</span>
      </h1>
      <p style="font-size: 16.5px; line-height: 1.6; color: var(--primary-light); margin-bottom: 25px;">
        Faites installer votre borne électrique ou prise renforcée par un électricien agréé IRVE dans le Nord (59). Estimez vos aides 2026 (crédit d'impôt de 500 €, TVA à 5,5%, subventions de la MEL et programme ADVEN) et comparez gratuitement jusqu'à 3 devis d'artisans.
      </p>

      <div class="trust-badges">
        <div class="badge">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          <span>Électriciens Certifiés IRVE</span>
        </div>
        <div class="badge">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>Étude &amp; Devis sous 48h</span>
        </div>
      </div>
    </div>

    <!-- Right Column -->
    <div>
      <StepsForm />
    </div>
  </div>
</section>
