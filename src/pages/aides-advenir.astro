---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import config from '../data/config.json';

const title = `Aides ADVENIR & Subventions Borne de Recharge Nord 2026`;
const description = `Estimez le montant de vos subventions pour la pose de votre borne électrique dans le Nord (59) : Crédit d'impôt 500 €, Prime ADVENIR 2026, TVA 5,5%.`;

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Aides ADVENIR 2026" }
];
---

<Layout title={title} description={description}>
  <SchemaMarkup 
    slot="head" 
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
    breadcrumbItems={breadcrumbItems}
  />

  <Breadcrumb items={breadcrumbItems} />

  <section class="static-page-section" style="padding: 50px 0 80px; background-color: var(--bg);">
    <div class="container">
      <div class="two-column-layout">
        
        <!-- Main Content -->
        <div class="static-main-content rich-text" style="background: var(--card-bg); padding: 40px; border-radius: var(--radius-md); box-shadow: var(--shadow-sm); border: 1px solid var(--border-color);">
          <h1 style="font-family: var(--font-heading); font-size: 32px; font-weight: 700; color: var(--primary); margin-bottom: 20px;">Financer votre Borne de Recharge dans le Nord (59)</h1>
          
          <p>
            Pour encourager la transition écologique dans le département du Nord, l'État, la Région Hauts-de-France et les collectivités locales (comme la MEL) proposent plusieurs dispositifs d'aides financières pour l'achat et la pose d'une borne de recharge électrique ou d'une prise renforcée à domicile.
          </p>

          <h2>1. Le Crédit d'Impôt National 2026 (500 €)</h2>
          <p>
            Reconduit et revalorisé en 2026, ce crédit d'impôt concerne les résidences principales ainsi que les résidences secondaires :
          </p>
          <ul style="margin-left: 20px; margin-bottom: 20px; display: flex; flex-direction: column; gap: 8px;">
            <li><strong>Montant :</strong> Égal à 75% du montant des dépenses de pose et d'achat de la borne, plafonné à <strong>500 € par point de charge</strong>.</li>
            <li><strong>Bénéficiaires :</strong> Tous les contribuables résidant en France (propriétaires, locataires ou occupants à titre gratuit), sans aucune condition de ressources.</li>
            <li><strong>Obligation :</strong> L'installation doit impérativement être facturée par une entreprise titulaire de la qualification IRVE.</li>
          </ul>

          <h2>2. Le Programme ADVENIR en Copropriété</h2>
          <p>
            Le programme ADVENIR finance spécifiquement l'installation de points de recharge en habitat collectif (immeubles, résidences de copropriété) à Lille, Roubaix, Tourcoing, et dans tout le 59 :
          </p>
          <ul style="margin-left: 20px; margin-bottom: 20px; display: flex; flex-direction: column; gap: 8px;">
            <li><strong>Pose individuelle (droit à la prise) :</strong> Financement de <strong>50% du devis</strong>, plafonné à <strong>960 € TTC</strong>.</li>
            <li><strong>Infrastructure collective de parking :</strong> Financement de 50% des travaux de raccordement général de la résidence (géré par le syndic), jusqu'à 8 000 € selon le nombre de places.</li>
          </ul>

          <h2>3. La TVA Réduite à 5,5%</h2>
          <p>
            Normalement fixée à 20%, la TVA est ramenée à <strong>5,5%</strong> sur l'achat du matériel et le coût de la main d'œuvre de l'électricien IRVE si votre logement (maison individuelle ou appartement) a plus de 2 ans.
          </p>

          <h2>4. Tableau récapitulatif du cumul des aides (Maison vs Copropriété)</h2>
          <table class="data-table">
            <thead>
              <tr>
                <th>Dispositif d'Aide</th>
                <th>Maison Individuelle</th>
                <th>Copropriété / Appartement</th>
                <th>Condition majeure</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Crédit d'impôt national</strong></td>
                <td class="price">500 €</td>
                <td class="price">500 €</td>
                <td>Électricien IRVE obligatoire</td>
              </tr>
              <tr>
                <td><strong>Prime ADVENIR Individuelle</strong></td>
                <td class="price">Non éligible</td>
                <td class="price">Jusqu'à 960 € (50%)</td>
                <td>Parking collectif / Immeuble</td>
              </tr>
              <tr>
                <td><strong>TVA Réduite</strong></td>
                <td class="price">5,5% (au lieu de 20%)</td>
                <td class="price">5,5% (au lieu de 20%)</td>
                <td>Logement de plus de 2 ans</td>
              </tr>
              <tr>
                <td><strong>Aide régionale MEL</strong></td>
                <td class="price">Selon conditions MEL</td>
                <td class="price">Selon conditions MEL</td>
                <td>Habiter l'une des 95 communes</td>
              </tr>
            </tbody>
          </table>

          <p style="font-size: 12.5px; color: var(--text-muted); margin-top: 30px;">
            ⚠️ <strong>Important :</strong> Toutes ces aides sont soumises à la facturation unique d'un installateur certifié IRVE. Ne signez pas de devis et ne versez pas d'acompte avant d'avoir déposé votre demande technique, sous peine de nullité de votre éligibilité.
          </p>
        </div>

        <!-- Sidebar -->
        <aside class="static-sidebar">
          <div class="sidebar-widget bg-green-gradient">
            <h3>🧮 Simulez vos Aides</h3>
            <p>Notre simulateur calcule instantanément votre crédit d'impôt et vos primes de raccordement pour votre véhicule.</p>
            <a href="/devis/" class="sidebar-cta-gold">Calculer mes aides →</a>
          </div>

          <div class="sidebar-widget">
            <h3>🛡️ Rôle d'Enedis</h3>
            <p style="font-size: 13px;">Enedis Nord s'occupe de la modification de votre compteur principal Linky (passage au triphasé si besoin), tandis que notre électricien IRVE gère la pose de la borne et des protections.</p>
          </div>
        </aside>

      </div>
    </div>
  </section>
</Layout>

<style>
  @media (max-width: 992px) {
    .two-column-layout {
      grid-template-columns: 1fr !important;
    }
  }
</style>
